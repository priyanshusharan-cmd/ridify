# ==========================================
# SERVER & DATABASE CONFIGURATION
# ==========================================
PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ridify

# ==========================================
# APP SECURITY & ADMINS
# ==========================================
ADMIN_EMAILS=admin@example.com
# Optional: If set, admin endpoints will also require this secret in the x-admin-secret header
# ADMIN_SECRET=your-secure-random-secret-here

# Allowed origin for CORS and Socket.IO (set to your frontend URL in production)
ALLOWED_ORIGIN=http://localhost:3000

# ==========================================
# SECURITY TUNING
# ==========================================
BCRYPT_ROUNDS=12
MAX_FIELD_LENGTH=500

# ==========================================
# SOCKET.IO
# ==========================================
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# ==========================================
# RIDE CONSTANTS
# ==========================================
MAX_ROUTE_POINTS=500
MIN_RIDE_DISTANCE_KM=1.5
SEARCH_RADIUS_DEFAULT_M=2000
SEARCH_TIME_WINDOW_MS=3600000
CHAT_MAX_LENGTH=1000

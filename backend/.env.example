# ==========================================
# SERVER & DATABASE CONFIGURATION
# ==========================================
PORT=5001
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ridify

# ==========================================
# JWT AUTHENTICATION (REQUIRED)
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=REPLACE_WITH_SEPARATE_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# APP SECURITY & ADMINS (REQUIRED)
# ==========================================
# ADMIN_SECRET is REQUIRED — no default is acceptable in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
ADMIN_EMAILS=admin@yourdomain.com

# ==========================================
# EMAILJS CONFIGURATION (OTP VERIFICATION)
# ==========================================
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# Allowed origins for CORS (comma-separated for multiple)
ALLOWED_ORIGIN=https://your-frontend-domain.com

# ==========================================
# SECURITY TUNING
# ==========================================
BCRYPT_ROUNDS=12
MAX_FIELD_LENGTH=500
MAX_FARE=9999

# ==========================================
# SOCKET.IO
# ==========================================
SOCKET_PING_INTERVAL=10000
SOCKET_PING_TIMEOUT=5000

# ==========================================
# RIDE CONSTANTS
# ==========================================
MAX_ROUTE_POINTS=500
MIN_RIDE_DISTANCE_KM=1.5
SEARCH_RADIUS_DEFAULT_M=2000
SEARCH_TIME_WINDOW_MS=3600000
CHAT_MAX_LENGTH=1000

# ==========================================
# EMAILJS CONFIGURATION (OTP VERIFICATION)
# ==========================================
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
